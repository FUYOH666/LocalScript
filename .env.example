# Copy to .env and adjust. Use only placeholders here in git: 127.0.0.1, your-host,
# /path/to/... — do not commit real TailScale IPs, tokens, or home directory paths.
#
# =============================================================================
# HTTP API (uvicorn, entrypoint: uv run localscript-api)
# =============================================================================
LOCALSCRIPT_API_HOST=127.0.0.1
LOCALSCRIPT_API_PORT=8765
LOCALSCRIPT_LOG_LEVEL=INFO

# =============================================================================
# LLM — OpenAI-compatible (vLLM gateway, Ollama, llama.cpp server, …)
# Base URL must include /v1 if the server serves OpenAI-style paths under /v1.
# =============================================================================
LOCALSCRIPT_LLM_BASE_URL=http://127.0.0.1:11434/v1
# MacBook + LM Studio (OpenAI-compatible): enable in your local .env only — see docs/RUNBOOK.md §0
# LOCALSCRIPT_LLM_BASE_URL=http://127.0.0.1:1234/v1
# LOCALSCRIPT_LLM_MODEL=your-loaded-model-id-from-lm-studio
LOCALSCRIPT_LLM_API_KEY=
LOCALSCRIPT_LLM_MODEL=qwen2.5-coder:7b
LOCALSCRIPT_LLM_TIMEOUT_S=120
LOCALSCRIPT_LLM_PROBE_TIMEOUT_S=10
LOCALSCRIPT_LLM_TEMPERATURE=0.2
# Optional perimeter guard for demo / CI:
# - allows loopback/private IPs
# - allows docker-style single-label hosts like `ollama`
# - allows extra exact hosts from LOCALSCRIPT_ALLOWED_HOSTS
# - rejects obvious public hosts such as example.com when enabled
# - dotted internal DNS names must be allowlisted explicitly
LOCALSCRIPT_ENFORCE_PRIVATE_HOSTS=false
LOCALSCRIPT_ALLOWED_HOSTS=
# Optional; when set must be >= 1
# LOCALSCRIPT_LLM_MAX_TOKENS=256

# -----------------------------------------------------------------------------
# Submission profile: Ollama 8GB VRAM / fixed lightweight settings
# Exact pull command:
#   ollama pull qwen2.5-coder:7b
# Recommended Ollama serve env:
#   OLLAMA_NUM_PARALLEL=1
# LocalScript-side mapping to the brief:
#   num_ctx=4096   -> LOCALSCRIPT_LLM_EXTRA_BODY_JSON options.num_ctx
#   num_predict=256 -> LOCALSCRIPT_LLM_MAX_TOKENS=256
#   batch=1        -> LOCALSCRIPT_LLM_EXTRA_BODY_JSON options.num_batch
#   parallel=1     -> LOCALSCRIPT_GENERATE_CANDIDATES_N=1 and MAX_PARALLEL=1
# Uncomment this block for the strict submission path:
# LOCALSCRIPT_LLM_MAX_TOKENS=256
# LOCALSCRIPT_LLM_EXTRA_BODY_JSON={"options":{"num_ctx":4096,"num_batch":1}}
# LOCALSCRIPT_GENERATE_CANDIDATES_N=1
# LOCALSCRIPT_GENERATE_CANDIDATES_MAX_PARALLEL=1
# LOCALSCRIPT_RAG_ENABLED=false
# LOCALSCRIPT_QUALITY_POLICY_ENABLED=false
# LOCALSCRIPT_QUALITY_JUDGE_ENABLED=false
#
# For the current local benchmark path on this machine, use the built-in
# `qwen7b-local-benchmark` profile from stands/run_jury_drill.py instead of hardcoding
# the values here. See docs/RUNBOOK.md §5.
#
# Remote formal drill (Ollama or any OpenAI-compatible server on a non-default port):
# set base URL only in your local .env or shell — do not commit real hostnames/IPs.
# Example shape (placeholders only):
#   LOCALSCRIPT_LLM_BASE_URL=http://your-host:6666/v1
# Then from repo root:
#   export LOCALSCRIPT_LLM_BASE_URL=http://your-host:6666/v1
#   PYTHONPATH=. uv run python stands/run_jury_drill.py --submission-profile ollama-8gb --compact --timeout 600
# The built-in `ollama-8gb` profile keeps submission limits but preserves a pre-set
# LOCALSCRIPT_LLM_BASE_URL instead of forcing 127.0.0.1:11434.

# Structured / guided output (gateway must support the fields you send)
LOCALSCRIPT_LLM_STRUCTURED_OUTPUT=false
# Example OpenAI-style: {"type":"json_schema","json_schema":{"name":"lua_wrap","schema":{"type":"object","properties":{"code":{"type":"string"}},"required":["code"]}}}
# LOCALSCRIPT_LLM_STRUCTURED_RESPONSE_FORMAT_JSON=
# Optional merge into request body (vLLM extras): {"guided_json":{"type":"object","properties":{"code":{"type":"string"}}}}
# LOCALSCRIPT_LLM_EXTRA_BODY_JSON=

# =============================================================================
# Agent loop
# =============================================================================
LOCALSCRIPT_AGENT_MAX_STEPS=5
LOCALSCRIPT_DIAGNOSTICS_PROMPT_MAX_ITEMS=20

# =============================================================================
# Quality — deterministic policy on final Lua + optional LLM judge + best-of-K
# =============================================================================
LOCALSCRIPT_QUALITY_POLICY_ENABLED=false
# Required when QUALITY_POLICY_ENABLED=true (e.g. octapi_stub)
# LOCALSCRIPT_QUALITY_POLICY_PRESET=octapi_stub

LOCALSCRIPT_QUALITY_JUDGE_ENABLED=false
# Empty = same as LLM_BASE_URL / LLM_MODEL
# LOCALSCRIPT_QUALITY_JUDGE_BASE_URL=http://127.0.0.1:8002/v1
# LOCALSCRIPT_QUALITY_JUDGE_MODEL=
LOCALSCRIPT_QUALITY_JUDGE_TIMEOUT_S=90
LOCALSCRIPT_QUALITY_JUDGE_TEMPERATURE=0.2
LOCALSCRIPT_QUALITY_JUDGE_MAX_TOKENS=512

# Parallel independent generations; winner by validation+sandbox then policy score
LOCALSCRIPT_GENERATE_CANDIDATES_N=1
LOCALSCRIPT_GENERATE_CANDIDATES_MAX_PARALLEL=1

# =============================================================================
# Validation tools — command (name on PATH or absolute path) + optional extra argv (shlex)
# =============================================================================
LOCALSCRIPT_STYLUA_COMMAND=stylua
LOCALSCRIPT_STYLUA_EXTRA_ARGS=
LOCALSCRIPT_STYLUA_TIMEOUT_S=30

LOCALSCRIPT_SELENE_COMMAND=selene
LOCALSCRIPT_SELENE_EXTRA_ARGS=
LOCALSCRIPT_SELENE_TIMEOUT_S=30

LOCALSCRIPT_LUALS_COMMAND=lua-language-server
LOCALSCRIPT_LUALS_EXTRA_ARGS=
LOCALSCRIPT_LUALS_TIMEOUT_S=120

LOCALSCRIPT_LUAC_COMMAND=luac
LOCALSCRIPT_LUAC_EXTRA_ARGS=
LOCALSCRIPT_LUAC_TIMEOUT_S=15

# Prepended to PATH for all tool subprocesses (use os.pathsep, e.g. on macOS/Linux ":")
# Example Homebrew: /opt/homebrew/bin
LOCALSCRIPT_PATH_EXTRA=

# Per-tool switches (false / 0 / no to disable)
LOCALSCRIPT_ENABLE_STYLUA=true
LOCALSCRIPT_ENABLE_SELENE=true
LOCALSCRIPT_ENABLE_LUALS=true
LOCALSCRIPT_ENABLE_LUAC=true

LOCALSCRIPT_ENABLE_LUACHECK=false
LOCALSCRIPT_LUACHECK_COMMAND=luacheck
LOCALSCRIPT_LUACHECK_EXTRA_ARGS=
LOCALSCRIPT_LUACHECK_TIMEOUT_S=60

# If true: POST /generate returns 503 until at least one linter/luac is on PATH
LOCALSCRIPT_REQUIRE_VALIDATORS=false

# If set: directory tree copied into each temp workspace before lint (selene.toml, .luarc.json, stubs/)
# Must exist; invalid path fails config load.
# LOCALSCRIPT_VALIDATION_WORKSPACE_TEMPLATE=/path/to/lua_workspace_template

# =============================================================================
# RAG — local corpus + OpenAI-compatible embeddings (e.g. BGE-M3)
# =============================================================================
LOCALSCRIPT_RAG_ENABLED=false
# Base URL: with or without /v1 (client builds …/v1/embeddings). See docs/LOCAL_AI_STACK.md
# LOCALSCRIPT_EMBEDDING_BASE_URL=http://your-embedding-host:9001
LOCALSCRIPT_EMBEDDING_API_KEY=
LOCALSCRIPT_EMBEDDING_MODEL=BAAI/bge-m3
# true = internal BGE-M3 API: return_dense in body, no model field; response uses dense_embedding
LOCALSCRIPT_EMBEDDING_BGE_M3_COMPAT=false
LOCALSCRIPT_EMBEDDING_TIMEOUT_S=30
# Directory with .md / .lua / .txt to index (required when RAG enabled)
# LOCALSCRIPT_RAG_SOURCES_DIR=/path/to/rag_corpus
LOCALSCRIPT_RAG_TOP_K=5
LOCALSCRIPT_RAG_MAX_CHUNK_CHARS=1500
LOCALSCRIPT_RAG_CHUNK_OVERLAP=200
# Optional JSON cache (chunks + vectors); invalidated via fingerprint of source mtimes
# LOCALSCRIPT_RAG_INDEX_CACHE_PATH=/path/to/rag_index.json
LOCALSCRIPT_RAG_HYBRID_BM25=true
LOCALSCRIPT_RAG_HYBRID_ALPHA=0.65
# Optional native /v1/rerank (BGE reranker; results with document + relevance_score)
# LOCALSCRIPT_RAG_RERANKER_BASE_URL=http://your-reranker-host:9002
LOCALSCRIPT_RAG_RERANKER_API_KEY=
# Leave empty if the server does not require a model id
LOCALSCRIPT_RAG_RERANKER_MODEL=
LOCALSCRIPT_RAG_RERANKER_TOP_N=8
LOCALSCRIPT_RAG_RERANKER_TIMEOUT_S=30

# =============================================================================
# Sandbox execution after static validation (luac on host vs Docker safe_run)
# =============================================================================
# none | luac_only | docker
LOCALSCRIPT_SANDBOX_EXECUTION_MODE=luac_only
LOCALSCRIPT_SANDBOX_DOCKER_IMAGE=localscript-sandbox:local
LOCALSCRIPT_SANDBOX_DOCKER_TIMEOUT_S=30
LOCALSCRIPT_SANDBOX_DOCKER_NETWORK_DISABLED=true

# =============================================================================
# Optional — GitLab arena (только локально; LocalScript API это не читает)
# =============================================================================
# Положите реальный токен в **локальный** `.env` (файл в `.gitignore`). Сюда в git — только плейсхолдер.
# Проверка из корня репо после `set -a; source .env; set +a` (или экспорт вручную):
#   curl -sS -H "PRIVATE-TOKEN: $GITLAB_TOKEN" "$GITLAB_BASE_URL/api/v4/user"
# Для `git push` по HTTPS удобнее macOS Keychain (`git credential`), а не переменная в URL.
# GITLAB_BASE_URL=https://git.truetecharena.ru
# GITLAB_TOKEN=
